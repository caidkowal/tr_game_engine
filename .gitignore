# macOS system files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Thumbnails
._.DS_Store
Thumbs.db

# Python cache and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd


# Build artifacts
c/build/
c/bin/
c/lib/
data_gen/build/

# Build artifacts placed in dist should be ignored
dist/*
# Allow the prebuilt shared libraries including the folder itself
!dist/
!dist/libpuzzlegen-linux-amd64.so
!dist/libpuzzlegen-linux-arm64.so


# Test artifacts
*.log
*.out
*.tmp

# Virtual environments
venv/
env/
.venv/
.env/

# IDE/editor configs
.vscode/
.idea/
*.swp
*.swo

# GitLab CI token-based clone URLs (just in case)
*.token



# Temporary files
*.bak
*.orig
